# Atlas local configuration template.
# Copy this file to config.env and fill in local secrets there.
# Do not commit config.env.

# Backend HTTP
ATLAS_SERVER_PORT=8080
ATLAS_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# MySQL profile defaults used by atlas-backend/src/main/resources/application.yml
ATLAS_DB_URL=jdbc:mysql://localhost:3306/atlas?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
ATLAS_DB_USERNAME=root
ATLAS_DB_PASSWORD=change-me
# Optional Flyway schema migrations. Keep false for the legacy manual schema.sql path.
# For a fresh MySQL database, set true to run db/migration/V1/V2.
# For an existing manual database, set true once to baseline at version 2; future V3+ migrations will apply.
ATLAS_FLYWAY_ENABLED=false

# Local H2 profile defaults used by start-atlas.bat and application-local.yml
ATLAS_H2_DATASOURCE_URL=jdbc:h2:file:./data/atlas;MODE=MySQL;DATABASE_TO_LOWER=TRUE;CASE_INSENSITIVE_IDENTIFIERS=TRUE;DB_CLOSE_DELAY=-1
ATLAS_H2_DATASOURCE_USERNAME=sa
ATLAS_H2_DATASOURCE_PASSWORD=

# JWT. Use a long random value in real deployments.
ATLAS_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-bytes
ATLAS_JWT_EXPIRE_HOURS=168

# Local file storage
ATLAS_PAPER_STORAGE_ROOT=data/papers
ATLAS_LIBRARY_STORAGE_ROOT=data/library

# Optional MinerU document conversion. Put the real token in local config.env only.
ATLAS_MINERU_ENABLED=true
ATLAS_MINERU_BASE_URL=https://mineru.net/api/v4
ATLAS_MINERU_AGENT_BASE_URL=https://mineru.net/api/v1/agent
ATLAS_MINERU_AGENT_ENABLED=true
ATLAS_MINERU_MODEL_VERSION=pipeline
ATLAS_MINERU_TIMEOUT_SECONDS=300
ATLAS_MINERU_CONNECT_TIMEOUT_SECONDS=30
ATLAS_MINERU_POLL_INTERVAL_MILLIS=5000
ATLAS_MINERU_OFFICE_ATTEMPT_TIMEOUT_SECONDS=90
ATLAS_MINERU_AGENT_MAX_FILE_SIZE_BYTES=10485760
ATLAS_MINERU_DOWNLOAD_RETRIES=3
ATLAS_MINERU_SUPPORTED_EXTENSIONS=pdf,doc,docx
MINERU_API_TOKEN=

# Optional Qdrant vector store
ATLAS_QDRANT_ENABLED=false
ATLAS_QDRANT_BASE_URL=http://localhost:6333
ATLAS_QDRANT_API_KEY=
ATLAS_QDRANT_COLLECTION_PREFIX=atlas_note_chunks

# Frontend / Vite
VITE_API_ORIGIN=http://localhost:8080
VITE_DEV_HOST=0.0.0.0
VITE_DEV_PORT=5173

# Optional VCP DailyNote integration.
# Copy real local paths to config.env only.
ATLAS_VCP_DAILYNOTE_ROOT=E:\path\to\VCPToolBox\dailynote
ATLAS_VCP_DEFAULT_NOTEBOOK=Atlas知识库日记本
ATLAS_VCP_DEEPWIKI_AGENT_NOTEBOOK=Atlas DeepWiki Agent 日记本
ATLAS_VCP_SYNC_AGENT_NOTEBOOK=Atlas VCP Sync Agent 日记本
ATLAS_VCP_PUBLIC_MEMORY_DSL=
ATLAS_VCP_DEEPWIKI_WORK_DSL=
ATLAS_VCP_SYNC_WORK_DSL=
